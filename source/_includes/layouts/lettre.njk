{% extends "layouts/lettres_list.njk" %}

{% block content %}
<article class="post">
	<header>
    	<h1>{{ title }}</h1>
    	<time datetime="{{ page.date | formatDate("YYYY-MM-DD") }}">{{ page.date | formatDate }}</time>
  	</header>
  	<div class="content">
		{{ content | safe }}
	</div>
</article>
{% endblock %}